# online.essl.in → 172.22.66.10:80
http:
  routers:
    online-essl:
      rule: "Host(`online.essl.in`)"
      entryPoints: ["websecure"]
      service: online-essl-svc
      middlewares: ["security-headers", "compress"]
      tls:
        certResolver: le

  services:
    online-essl-svc:
      loadBalancer:
        servers:
          - url: "http://172.22.66.10:80"
        passHostHeader: true
